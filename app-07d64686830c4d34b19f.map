﻿.blog-container {
    display: flex;
    flex-direction: column;
    align-items: center;

    .content-container {
        background-color: $offwhite;
        padding: 0 3rem 3rem 3rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 85vw;

        .admin-blog-wrapper {
            display: flex;
            justify-content: space-between;
            align-items: center;

            .blog-delete {
                align-self: flex-start;
                cursor: pointer;
                color: $dark-teal;
                font-size: 1.75rem;
                position: relative;
                right: 5.5rem;
                top: 4.4rem;

                &:hover {
                    color: $warning;
                }
            }
        }

        .new-blog-link {
            position: fixed;
            right: 0;
            margin: 3rem 12rem 0 0;
            a {
                color: $dark-teal;
                font-size: 3rem;
                cursor: pointer;

                &:hover {
                    color: $blue;
                }
            }
        }

        a {
            text-decoration: none;
            color: $teal;
            transition: 0.5s ease-in-out;

            &:hover {
                color: $dark-teal;
            }
        }

        h1 {
            margin-top: 3rem;
            font-size: 2.15rem;
            color: $teal;
            text-shadow:
                        .1rem .1rem $dark-teal,
                        -.1rem -.1rem $dark-teal,
                        -.1rem .1rem $dark-teal,
                        .1rem -.1rem $dark-teal,
                        .11rem 0rem $dark-teal,
                        -.11rem 0rem $dark-teal,
                        0rem .11rem $dark-teal,
                        0 -.11rem $dark-teal;
            // -webkit-text-stroke: .05rem $charcoal;
            // text-stroke: .05rem $charcoal;
        }

        .featured-image-wrapper {
            img {
                margin: 2rem 0 3rem;
                width: 100%;
                height: 26rem;
                border-radius: .5rem;
                object-fit: cover;
            }
        }

        .content {
            line-height: 1.5rem;
        }
    }
}

.blog-item-title {
    position: relative;
    right: 2rem;
    top: 1rem;
    max-width: 72vw;
}

.blog-item-details {
    color: $blue;
    width: 76vw;
    line-height: 1.5rem;
}
